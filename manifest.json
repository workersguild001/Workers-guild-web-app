File 6: service-worker.js (Offline Support)
Instructions: Create a new file named service-worker.js. This runs in the background to handle the installation process.

self.addEventListener('install', (event) => {
  event.waitUntil(
    caches.open('guild-v1').then((cache) => {
      return cache.addAll([
        '/',
        'index.html',
        'gateway.html',
        'recruitment.html',
        'success.html',
        'manifest.json'
      ]);
    })
  );
});

self.addEventListener('fetch', (event) => {
  event.respondWith(
    caches.match(event.request).then((response) => {
      return response || fetch(event.request);
    })
  );
});
